define l = Character("利希", color="#d44b4b")
define m = Character("马塔拉佐", color="#6b8fd6")
define s = Character("工作人员", color="#aaaaaa")
define r = Character("记者", color="#dddddd")
define n = Character(None)

default anger = 0
default soft = 0
default tease = 0
default italian = 0
default tie_cg = False
default video_cg = False
default visit_cg = False
default coffee_accept = False

label start:

    scene black
    with fade

    n "【特别特典】"
    n "《德比夜失踪事件》"

    n "这是我今年第三次见到马塔拉佐。"
    n "也是第三次输给皇家社会。"

    n "第一次，他赢了。"
    n "第二次，他又赢了。"
    n "第三次，也就是今晚，他还是赢了。"

    n "终场哨响时，我甚至不想看他。"

    n "可他偏偏隔着人群看了我一眼。"
    n "很短。"
    n "但太明显。"
    n "像故意的。"

    l "……烦死了。"

    n "我转身就走。"
    n "手机震了一下。"

    m "利希。"

    menu:
        "我决定："

        "已读不回":
            $ anger += 2
            n "我锁屏。"
            m "生气了？"
            m "Piccolo romano arrabbiato."
            n "生气的小罗马人。"

        "回一个句号":
            $ soft += 1
            $ tease += 1
            l "。"
            m "至少还愿意回我。"
            m "等我。"

        "回：滚":
            $ tease += 2
            l "滚。"
            m "你骂人次数变少了。"
            m "说明还没有特别生气。"

    n "赛后通道里全是人。"

    s "Mister呢？"
    s "发布会还有八分钟！"
    s "刚才不是还在这里吗？"

    n "很好。"
    n "皇家社会主教练本人失踪了。"

    n "我装作没听见，继续往前走。"

    n "下一秒，一只手从旁边伸出来。"
    n "不重，却很准确地扣住我的手腕。"

    l "马塔拉佐。"

    m "终于肯停了？"

    l "放手。"

    m "不放。"

    l "你是不是有病？"

    m "今晚可能有一点。"

    n "他把我往旁边的小通道一带。"
    n "门在身后轻轻合上。"
    n "外面的嘈杂声被隔开。"
    n "这里只剩一盏很暗的灯。"

    l "你又失踪？"

    m "不是失踪。"

    l "那是什么？"

    m "哄你。"

    menu:
        "我："

        "我不需要你哄。":
            $ anger += 2
            l "我不需要。"
            m "你需要。"
            l "你凭什么判断？"
            m "你从终场开始就不看我。"

        "你连续赢我三次。":
            $ soft += 2
            l "你连续赢我三次。"
            m "我知道。"
            l "你知道还来惹我？"
            m "因为你不理我。"

        "你先滚去发布会。":
            $ tease += 1
            l "你先滚去发布会。"
            m "发布会不会跑。"
            l "我会跑？"
            m "你刚才已经在跑了。"

    n "我想走。"
    n "马塔拉佐往前一挡。"

    n "小通道太窄。"
    n "我往左，他也往左。"
    n "我往右，他还是挡着。"

    l "你幼不幼稚？"

    m "赢了德比的人有一点特权。"

    l "没有这种东西。"

    m "有。"

    n "他忽然向前一步。"
    n "灯光被他挡掉一半。"
    n "阴影落下来。"

    n "我下意识后退。"
    n "直到后背碰到墙。"

    l "你别拿身高压人。"

    m "我没有。"

    l "你有。"

    m "那我低一点。"

    n "他真的低下头。"
    n "距离反而更近。"

    l "……你是不是脑子坏了？"

    m "可能。"
    m "因为你一直不理我。"

    menu:
        "我决定："

        "推开他":
            $ anger += 2
            n "我伸手推他。"
            l "别靠这么近。"
            m "推得这么轻？"
            l "我怕皇家社会主教练坏了还要赔。"
            jump normal_tunnel

        "抓住他的领带":
            $ tie_cg = True
            $ tease += 3
            $ soft += 1
            $ italian += 1
            jump tie_bow_cg

        "不说话，只看着他":
            $ soft += 2
            n "我没说话。"
            n "只是抬头看他。"
            n "马塔拉佐脸上的笑慢慢淡了一点。"
            m "真的气坏了？"
            l "……"
            m "Mi dispiace."
            n "对不起。"
            jump normal_tunnel

        "高个子很了不起？":
            $ tease += 1
            $ soft += 1
            l "高个子很了不起？"
            m "不是。"
            n "他低头，故意把声音放轻。"
            m "但这样看你，很方便。"
            l "方便什么？"
            m "方便确认你嘴硬的时候，耳朵是不是红了。"
            jump normal_tunnel


label tie_bow_cg:

    n "我抬手抓住他的领带。"

    l "你赢球赢疯了？"

    m "可能。"

    l "三次。连续三次。"

    m "我记得。"

    l "你最好记得。"

    n "我本来只是想把他拽低一点。"
    n "可马塔拉佐顺着我的力道低下头。"
    n "太配合了。"
    n "配合得像早就等着我这么做。"

    m "利希。"

    l "干嘛？"

    m "你抓得太轻了。"

    l "……你有病吧。"

    n "他笑了一下。"

    n "下一秒，他抬手，慢条斯理地解开了自己的领带。"

    l "你干什么？"

    m "既然你这么喜欢。"

    n "深色领带从他的衣领间滑下来。"
    n "我的手还没来得及收回，就被他轻轻握住。"

    l "马塔拉佐。"

    m "别动。"

    n "他说得很轻。"
    n "但不是命令。"
    n "更像在逗一只已经炸毛、却还没真的咬人的小动物。"

    n "他把领带绕过我的手腕。"
    n "没有勒紧。"
    n "只是松松地、漂亮地打了个蝴蝶结。"
    n "像一件临时起意的恶劣礼物。"

    n "【CG解锁：领带蝴蝶结】"

    # show expression "images/cg/tie_bow.png"
    # with dissolve

    l "……你把我当什么？"

    m "战利品。"

    l "你再说一遍？"

    m "不对。"

    n "他低头看着那个蝴蝶结。"

    m "不是战利品。"
    m "是我今晚最想哄好的人。"

    l "你少用这种话转移重点。"

    m "那我换意大利语？"

    l "不准。"

    m "Troppo tardi."

    n "太晚了。"

    m "Piccolo romano carino."

    n "可爱的小罗马人。"

    l "我真的会踢你。"

    m "可以。"

    n "他靠得更近。"

    m "但先让我亲一下。"

    l "谁同意了？"

    m "你可以推开我。"

    n "他说完，没有立刻动。"
    n "只是低头看着我。"
    n "像在等我最后的反应。"

    menu:
        "我："

        "偏开脸，但没有推开":
            $ soft += 2
            n "我偏开脸。"
            l "只能一下。"
            m "嗯。"
            n "他低低笑了一声。"
            n "下一秒，一个很轻的吻落在我的侧脸。"

        "抬头瞪他":
            $ tease += 2
            n "我抬头瞪他。"
            l "你敢？"
            m "敢。"
            n "他回答得太快。"
            n "下一秒，他低头亲了下来。"
            n "不是很重。"
            n "却足够让我听见自己心跳漏了一拍。"

        "用蝴蝶结绑着的手推他":
            $ anger += 1
            $ soft += 1
            n "我用那只被蝴蝶结松松绑住的手推他。"
            l "发布会。"
            m "我知道。"
            l "那你还不走？"
            m "因为你还没消气。"
            n "他低头，在我的手指旁边轻轻碰了一下。"
            n "像一个偷走边角的吻。"

        "小声说：只能一下。":
            $ soft += 4
            $ italian += 1
            l "……只能一下。"
            n "马塔拉佐明显愣了一下。"
            m "利希。"
            l "你再不亲就没有了。"
            m "Adesso sì che sei pericoloso."
            n "现在你才危险。"
            n "他低头亲下来。"
            n "很轻。"
            n "却停得比一下久得多。"

    s "Mister！！"

    n "门外忽然又传来工作人员的声音。"

    n "我立刻低头去扯那个领带结。"

    l "解开。"

    m "很漂亮。"

    l "我说解开。"

    m "好。"

    n "他终于伸手，把那个漂亮得过分的蝴蝶结解开。"
    n "领带重新落回他手里。"
    n "但我的手腕上仿佛还残留着那一点布料的温度。"

    jump normal_tunnel


label normal_tunnel:

    m "我不会为赢球道歉。"

    l "那你道歉干什么？"

    m "因为你不高兴。"

    n "这句话比刚才所有逗人的话都轻。"

    m "我可以哄你。"

    l "谁要你哄。"

    m "你。"

    l "我没有。"

    m "有。"

    s "Mister？"

    n "门外忽然传来工作人员的声音。"

    s "您在这附近吗？发布会还有六分钟！"

    n "马塔拉佐忽然伸手。"
    n "一把把我圈到他胸前。"

    n "动作很轻。"
    n "但很准。"

    n "我的额头差点撞上他的西装。"

    l "马塔拉佐！"

    m "Shh."

    n "他低头，声音落在我发顶。"

    m "Non muoverti."

    n "别动。"

    l "你才别动。"

    m "Bravo."

    n "乖。"

    l "……你完了。"

    menu:
        "这种时候我："

        "用手肘怼他":
            $ anger += 2
            l "你再说意大利语，我就开门。"
            m "那我小声说。"
            l "重点是这个吗？"

        "低声骂他":
            $ tease += 2
            l "你真的很烦。"
            m "Lo so."
            n "我知道。"
            l "知道还不改？"
            m "今晚不改。"

        "抓紧他的西装":
            $ soft += 2
            n "我本来想推开他。"
            n "但外面的人停在门口。"
            n "最后只抓住了他的西装。"
            m "Così va meglio."
            n "这样好多了。"
            l "别误会。"

        "抬头瞪他":
            $ italian += 1
            $ tease += 1
            n "我抬头瞪他。"
            n "这个角度很糟糕。"
            m "Che occhi."
            n "这双眼睛啊。"
            l "不要突然说这种话。"

    n "门外的人停了一会儿。"

    s "奇怪……"

    n "脚步声终于走远。"

    n "我立刻推他。"

    l "松开。"

    m "还气吗？"

    l "气。"

    m "比刚才少一点？"

    l "更多了。"

    m "骗人。"

    l "你连续赢我三次。"

    m "嗯。"

    l "下次我一定赢回来。"

    m "好。"
    m "我等你。"

    l "别一副很高兴的样子。"

    m "我就是高兴。"

    l "你赢了当然高兴。"

    m "不是因为这个。"

    l "那是因为什么？"

    m "因为你说还有下次。"

    s "Mister！！真的不能再拖了！！"

    l "发布会。"

    m "嗯。"

    l "现在。"

    m "你先说一句。"

    l "说什么？"

    m "说你会理我。"

    menu:
        "我："

        "看你表现。":
            $ tease += 2
            l "看你表现。"
            m "那我今晚表现不好？"
            l "非常差。"
            m "那发布会后补考。"

        "发布会后再说。":
            $ soft += 2
            l "发布会后再说。"
            m "这就够了。"
            l "我还没答应什么。"
            m "但你没有拒绝。"

        "滚去发布会。":
            $ anger += 2
            l "滚去发布会。"
            m "这是愿意理我的意思吗？"
            l "这是我想让你滚的意思。"
            m "听起来差不多。"

        "Vattene.":
            $ italian += 2
            l "Vattene."
            n "走开。"
            m "你学意大利语就为了骂我？"
            l "对。"
            m "发音很好。"
            l "滚。"

    n "马塔拉佐终于松开我。"
    n "他后退一步，整理了一下外套。"
    n "又恢复成那个冷静体面的主教练。"

    menu:
        "最后我："

        "帮他把领带扯正":
            $ soft += 2
            n "我伸手，把他的领带扯正。"
            l "别让记者看出来你刚才像逃课生。"
            m "你帮我整理的，他们只会觉得我赢得很体面。"

        "故意把领带弄得更歪":
            $ tease += 2
            n "我伸手，把他的领带又扯歪了一点。"
            l "报复。"
            m "很幼稚。"
            l "我连续输三次，有幼稚的权利。"

        "转身就走":
            $ anger += 1
            l "自己整理。"
            m "真的不管我？"
            l "你不是很会失踪吗？自己找镜子。"

    n "马塔拉佐走到门边，又回头。"

    m "今晚接电话吗？"

    l "不接。"

    m "那我多打几次。"

    l "你敢。"

    m "敢。"

    n "他说完，终于走进发布会方向的灯光里。"

    jump video_part


label video_part:

    scene black
    with fade

    n "凌晨 1:43。"

    n "我本来已经准备睡了。"

    n "手机忽然震动。"

    n "【Matarazzo】"

    n "视频通话。"

    n "我盯着看了三秒。"

    n "挂掉。"

    n "下一秒。"
    n "又打过来。"

    n "第三次。"

    menu:
        "我决定："

        "继续挂":
            $ anger += 2
            n "我又挂了。"
            n "十秒后。"
            m "你真的不接？"
            m "那我只能亲自来。"
            l "……？"
            m "我说真的。"

        "接，但不开摄像头":
            $ tease += 1
            n "我接了。"
            l "干嘛。"
            m "不开视频？"
            l "不想看你。"
            m "骗人。"
            m "你刚才停顿三秒才接。"

        "开视频":
            $ soft += 2
            $ video_cg = True
            n "视频接通。"

    n "最后我还是接了。"

    n "下一秒。"

    n "马塔拉佐那张脸直接占满屏幕。"

    n "头发明显刚洗完。"
    n "穿着黑色T恤。"
    n "背景是酒店。"

    n "圣塞巴斯蒂安。"

    n "【CG解锁：深夜视频】"

    # show expression "images/cg/video_call.png"
    # with dissolve

    l "……你有病？"

    m "已经说过了。"

    m "今晚可能有一点。"

    l "凌晨一点半打视频？"

    m "因为你白天不理我。"

    l "你赢了。"

    m "所以？"

    l "所以你活该。"

    n "马塔拉佐笑了。"
    n "那种赢完球之后一直没收干净的笑。"

    m "手腕还在红吗？"

    l "……？"

    m "领带。"

    l "滚。"

    m "让我看看。"

    l "不给。"

    m "Piccolo romano."

    n "小罗马人。"

    l "闭嘴。"

    m "Piccolo romano molto arrabbiato."

    n "非常生气的小罗马人。"

    l "你除了这个还会说别的吗？"

    m "Sei carino quando fai il broncio."

    n "你闹脾气的时候很可爱。"

    l "你又在说什么？"

    m "夸你。"

    l "我不信。"

    m "Mi sei mancato."

    n "我想你了。"

    l "……"

    m "È la terza volta quest’anno."

    n "这是今年第三次见面。"

    m "Troppo poco."

    n "太少了。"

    l "你看什么？"

    m "Guardo il mio romano."

    n "我在看我的罗马人。"

    l "谁是你的？"

    m "你。"

    l "……你今晚真的赢疯了。"

    m "可能。"

    l "你明天不用训练？"

    m "下午。"

    l "那你快睡。"

    m "你先。"

    l "为什么？"

    m "我想确认你不生气了。"

    l "我还气。"

    m "那我继续哄。"

    l "你很烦。"

    m "Lo so."

    n "我知道。"

    menu:
        "我："

        "你挂。":
            $ tease += 1
            l "你挂。"
            m "你先。"
            l "凭什么？"
            m "因为你会偷偷熬夜。"

        "不挂。":
            $ soft += 2
            l "不挂。"
            m "嗯。"

        "唱首歌。":
            $ italian += 2
            $ soft += 1
            l "唱首歌。"
            m "什么？"
            l "意大利人不是都会唱歌？"
            m "这是偏见。"
            l "所以你唱不唱？"
            m "好。"
            n "然后他真的低声唱起来。"
            n "听不懂。"
            n "但很慢。"
            n "像哄人睡觉。"

    n "我靠在枕头上。"
    n "本来只想再说五分钟。"

    n "结果不知道什么时候开始。"
    n "困意慢慢压上来。"

    n "视频没挂。"
    n "手机还亮着。"

    n "马塔拉佐还在说话。"
    n "低低的。"
    n "慢慢的。"

    m "Piccolo romano."
    m "Carino."
    m "Dormi."

    n "睡吧。"

    l "……烦。"

    m "Sì."

    n "嗯。"

    l "闭嘴。"

    m "Va bene."

    n "好。"

    n "我最后一次睁眼。"
    n "看见马塔拉佐正低头笑。"

    n "像在看什么特别乖的小动物。"

    n "下一秒。"
    n "意识慢慢沉下去。"

    scene black
    with dissolve

    n "凌晨 3:11。"

    n "圣塞巴斯蒂安。"

    n "马塔拉佐还没挂视频。"

    n "他安静看了十分钟。"

    n "屏幕里，我睡觉不太老实。"
    n "被子掉了一半。"
    n "手机歪着。"
    n "头发乱。"

    n "偶尔还会皱眉。"
    n "像梦里都还在气连续输三场。"

    m "Piccolo romano…"
    m "Dormi bene."

    n "睡好一点。"

    n "他沉默两秒。"

    n "然后低头看时间。"

    n "3:14。"

    n "从圣塞巴斯蒂安到潘普洛纳。"

    n "不算远。"

    n "几分钟后。"

    n "皇家社会主教练失踪第二次。"

    jump morning_visit


label morning_visit:

    scene black
    with fade

    n "第二天。"

    n "上午 8:27。"

    n "我被门响吵醒。"

    n "第一反应。"

    n "谁？"

    n "第二反应。"

    n "不对。"

    n "钥匙声。"

